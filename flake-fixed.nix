[{'Headless Emacs runner for init.el logging";\n\n  inputs.nixpkgs.url =': 'ithub:NixOS/nixpkgs/nixos-24.11', 'x86_64-linux"\n        "aarch64-linux': 'forSystem = system:\n        let\n          pkgs = import nixpkgs { inherit system;'}, {'emacs-headless";\n            runtimeInputs = [ pkgs.emacs-nox pkgs.coreutils ];\n            text = \'\'\n              set -euo pipefail\n\n              repo_root=': '${EMACS_HEADLESS_ROOT:-$(pwd)}"\n              init_file="\'', 'EMACS_HEADLESS_INIT': 'repo_root/init.el'}, {'EMACS_HEADLESS_LOG_DIR': 'repo_root/.agent-shell/emacs'}, {'test-runner";\n            runtimeInputs = [ pkgs.emacs-nox pkgs.coreutils ];\n            text = \'\'\n              #!/bin/bash\n              set -euo pipefail\n              \n              # Bypass nix-ld conflicts\n              unset NIX_LD LD_LIBRARY_PATH\n              export PATH="$(echo "$PATH': "tr ':' '\n' | grep -v nix-ld | tr '\n' ':')", 'test_file=': '${1:-/home/zoya/pro/tests/unit/ai-openrouter-api.el}"\n              \n              echo "=== Running test: $test_file ==="\n              \n              emacs --batch -Q \n                --eval "(progn \n                  (setq user-emacs-directory "/home/zoya/pro") \n                  (add-to-list \'load-path "/home/zoya/pro/интеграция") \n                  (load-file "$test_file"))" \n                2>&1\n              \n              echo "=== Test completed ==="\n            \'', 'app";\n              program =': {'emacs-headless}/bin/emacs-headless': ''}, '$PATH': "tr ':' '\n' | grep -v nix-ld | tr '\n' ':')", '=== Nix devShell: emacs ready (nix-ld bypassed) ===': ';\n          };\n\n          devShells.test = pkgs.mkShell {\n            packages = [ pkgs.emacs-nox pkgs.git ];\n            buildInputs = [ pkgs.emacs-nox ];\n            shellHook =', '=== Test devShell: ready for e2e tests ==="\n              echo': 'un: emacs --batch -Q -l tests/e2e/<name>.el', 'system': 'forSystem system).packages);\n      apps = nixpkgs.lib.genAttrs systems (system: (forSystem system).apps);\n      devShells = nixpkgs.lib.genAttrs systems (system: (forSystem system).devShells);'}]