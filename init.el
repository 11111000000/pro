;;; init.el --- Главный файл инициализации Emacs-конфигурации -*- lexical-binding: t; -*-
;;
;; Автор: Пётр <11111000000@email.com>
;; Версия: 2.0
;; Keywords: init, configuration, emacs
;; URL: https://github.com/username/emacs.d/blob/main/init.el
;;
;;; Commentary:
;;
;; Главный файл инициализации, загружающий все модули конфигурации в правильном порядке.
;; Модули организованы по категориям:
;;   - инфраструктура: базовые утилиты (загрузка, установка пакетов, оптимизация)
;;   - среда: настройка окружения (редактор, графика, шрифты, мониторы)
;;   - интерфейс: UI компоненты (окна, буферы, справка)
;;   - навигация: поиск и доступ (Vertico, Dired)
;;   - разработка: программирование (языки, LSP, отладка)
;;   - организация: Org-mode и продуктивность
;;   - интеграция: внешние сервисы (AI, терминалы, сеть)
;;   - инструменты: утилиты (игры, устройства, функции)
;;   - языки: языковые пакеты (Nix, Guix)
;;   - платформа: платформенные настройки
;;
;; Порядок загрузки учитывает зависимости: инфраструктура загружается первой.
;;
;;; Code:

;;; ---------------------------------------------------------------------------
;;; 0. Настройка путей и базовая инициализация
(add-to-list 'load-path (expand-file-name "инфраструктура" user-emacs-directory))

(require 'загрузить)

;;; ---------------------------------------------------------------------------
;;; 1. Инфраструктура (базовые утилиты, должны загружаться первыми)
(загрузить 'про-оптимизацию)       ;; Оптимизация загрузки
(загрузить 'про-менеджер-пакетов)  ;; Пакетный менеджер
(загрузить 'загрузить)             ;; Утилита загрузки (уже require, но для согласованности)
(загрузить 'установить-из)         ;; Установка из VCS
(загрузить 'тихо-применить)        ;; Подавление сообщений

;;; ---------------------------------------------------------------------------
;;; 2. Среда (настройка окружения)
(загрузить 'про-редактор)           ;; Базовые настройки редактора
(загрузить 'про-текстовый-режим)    ;; TTY/консоль
(загрузить 'про-внешний-вид)        ;; Визуальный интерфейс
(загрузить 'про-цвет)               ;; Цветовая схема
(загрузить 'про-шрифты)             ;; Шрифты и mixed-pitch
(загрузить 'про-мониторы)           ;; Мультимонитор
(загрузить 'про-графическую-среду)  ;; EXWM

;;; ---------------------------------------------------------------------------
;;; 3. Интерфейс (UI компоненты)
(загрузить 'про-буферы)             ;; Управление буферами
(загрузить 'про-окна)               ;; Управление окнами
(загрузить 'про-доску)              ;; Дашборд
(загрузить 'про-стартовый-экран)    ;; Стартовый экран
(загрузить 'про-справку)            ;; Справка и подсказки
(загрузить 'про-тему-vterm)         ;; Тема для vterm

;;; ---------------------------------------------------------------------------
;;; 4. Навигация (поиск и доступ)
(загрузить 'про-быстрый-доступ)     ;; Vertico, Consult, Orderless
(загрузить 'про-файлы-и-папки)      ;; Dired
(загрузить 'про-режим-бога)         ;; God mode

;;; ---------------------------------------------------------------------------
;;; 5. Разработка (программирование)
(загрузить 'про-автодополнение)     ;; Corfu, Cape
(загрузить 'про-код)                ;; Основная среда (treesit, eglot)
(загрузить 'про-управление-проектами) ;; Projectile
(загрузить 'про-отладку)            ;; Отладочные флаги
(загрузить 'про-код-на-lisp)        ;; Lisp/Elisp
(загрузить 'про-код-на-python)      ;; Python
(загрузить 'про-код-на-javascript)  ;; JavaScript/TypeScript
(загрузить 'про-код-на-rust)        ;; Rust
(загрузить 'про-код-на-c)           ;; C#
(загрузить 'про-код-на-haskell)     ;; Haskell
(загрузить 'про-код-на-java)        ;; Java/Android
(загрузить 'про-код-на-flutter)     ;; Dart/Flutter
(загрузить 'про-фикс-corfu)         ;; Исправления для Corfu

;;; ---------------------------------------------------------------------------
;;; 6. Организация (продуктивность)
(загрузить 'про-организацию)        ;; Org-mode
(загрузить 'про-время)              ;; Календарь и время
(загрузить 'про-клавиши-из-org)     ;; Загрузка клавиш из Org
(загрузить 'про-китайский-календарь) ;; Китайский календарь

;;; ---------------------------------------------------------------------------
;;; 7. Интеграция (внешние сервисы)
(загрузить 'про-терминалы)          ;; Vterm, Eshell
(загрузить 'про-ии)                 ;; AI (GPTEL)
(загрузить 'про-интернет-общение)   ;; Telegram (telega)
(загрузить 'про-интернет-сервисы)   ;; Сетевые сервисы
(загрузить 'про-словари-и-перевод)  ;; Словари и перевод
(загрузить 'про-новости)            ;; Новости (Elfeed)

;;; ---------------------------------------------------------------------------
;;; 8. Инструменты (утилиты)
(загрузить 'про-игры)               ;; Игры
(загрузить 'про-шифрование)        ;; Шифрование
(загрузить 'про-устройства)         ;; Устройства
(загрузить 'про-малую-механизацию)  ;; Утилита создания биндов
(загрузить 'про-функции)            ;; Вспомогательные функции
(загрузить 'про-историю)           ;; История и undo
(загрузить 'про-инструменты)        ;; Разные инструменты
(загрузить 'про-org-capture-posframe) ;; Org-capture posframe

;;; ---------------------------------------------------------------------------
;;; 9. Языки (языковые пакеты)
(загрузить 'про-nix)               ;; Nix
(загрузить 'про-guix)              ;; Guix

;;; ---------------------------------------------------------------------------
;;; 10. Платформа (платформенные настройки)
(загрузить 'про-огрызок)           ;; macOS

;;; ---------------------------------------------------------------------------
;;; 11. Дополнительные загрузки
;; Загрузка клавиш из Org-таблицы (если файл существует)
(when (file-exists-p (expand-file-name "про-сочетания-клавиш.org" user-emacs-directory))
  (загрузить-org (expand-file-name "про-сочетания-клавиш.org" user-emacs-directory)))

;;; init.el ends here